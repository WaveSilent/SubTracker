@page
@model SubscriptionManager.Pages.Subscriptions.CreateModel
@{
    ViewData["Title"] = "Добавить подписку";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-plus-circle"></i> Добавить новую подписку
                    </h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <!-- Название подписки -->
                        <div class="mb-3">
                            <label asp-for="Subscription.Name" class="form-label">Название подписки</label>
                            <input asp-for="Subscription.Name" class="form-control" placeholder="Например: Netflix, Яндекс Музыка..." />
                            <span asp-validation-for="Subscription.Name" class="text-danger"></span>
                        </div>

                        <!-- Категория -->
                        <div class="mb-3">
                            <label asp-for="Subscription.CategoryId" class="form-label">Категория</label>
                            <select asp-for="Subscription.CategoryId" asp-items="Model.Categories" class="form-select">
                                <option value="">-- Выберите категорию --</option>
                            </select>
                            <span asp-validation-for="Subscription.CategoryId" class="text-danger"></span>
                        </div>

                        <!-- Стоимость и день списания в одной строке -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Subscription.MonthlyPrice" class="form-label">Стоимость в месяц (₽)</label>
                                <input asp-for="Subscription.MonthlyPrice" class="form-control" type="number" step="0.01" min="0" />
                                <span asp-validation-for="Subscription.MonthlyPrice" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Subscription.BillingDay" class="form-label">День списания</label>
                                <input asp-for="Subscription.BillingDay" class="form-control" type="number" min="1" max="31" />
                                <span asp-validation-for="Subscription.BillingDay" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Заметки -->
                        <div class="mb-3">
                            <label asp-for="Subscription.Notes" class="form-label">Заметки (необязательно)</label>
                            <textarea asp-for="Subscription.Notes" class="form-control" rows="3" placeholder="Дополнительная информация..."></textarea>
                            <span asp-validation-for="Subscription.Notes" class="text-danger"></span>
                        </div>

                        <!-- Кнопки -->
                        <div class="d-flex justify-content-between">
                            <a asp-page="/Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Назад
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Сохранить
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
